/* ─────────────────────────────────────────────
   STAT MINI CARD
───────────────────────────────────────────── */
.stat-card {
  border-radius: 16px;
  border: 1px solid var(--border-soft);
  background: rgba(255,255,255,0.02);
  box-shadow: var(--shadow-card);
  padding: 1rem;
