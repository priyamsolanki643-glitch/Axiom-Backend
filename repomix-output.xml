          filter: blur(25px);
          border-radius: 50%;
          pointer-events: none;
          z-index: 1;
        }
      `}</style>

      {/* ── Header (Ultra Minimal) ── */}
      <header 
        className="flex items-center justify-end px-6 py-6 relative z-10 w-full transition-opacity duration-700"
        style={{ opacity: visible && !isExiting ? 1 : 0 }}
