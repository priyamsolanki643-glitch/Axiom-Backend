          0%  { background-position: -200% 0; }
          to  { background-position:  200% 0; }
        }

        .btn-eclipse-glow {
          position: absolute;
          top: 50%;
          left: 50%;
          transform: translate(-50%, -50%);
          width: 140px;
          height: 60px;
